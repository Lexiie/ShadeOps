# ShadeOps runtime environment
# Copy to .env.local for local development or set these values in Vercel project settings.

# Supabase API persistence. Required in production unless DATABASE_URL + generated Prisma client are used.
# Use the service role key only on the server. Never expose it with NEXT_PUBLIC_.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"

# Optional Prisma/Postgres path for schema generation or migration jobs.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Wallet session signing. Required in production; generate a long random value.
SHADEOPS_SESSION_SECRET="replace-with-a-long-random-secret"

# Workspace authorization entries are comma-separated: workspaceId:walletAddress:role
# Roles: owner, admin, reviewer
# Example: default:4Ym2txdd8uvG8uo39Vnrqwa7fZNQWJeRaoQTSJiK67HH:owner,default:ECNGa5typxnu5N89izerq3zuK1ZFcLvZVft4Mzao5Yat:reviewer
SHADEOPS_WORKSPACE_MEMBERS="default:REPLACE_WITH_ADMIN_WALLET:owner"

# Server-side Solana RPC used for balance verification and proof signature checks.
SOLANA_RPC_URL="https://api.devnet.solana.com"

# Browser-side Solana RPC used by wallet/protocol execution paths.
NEXT_PUBLIC_SOLANA_NETWORK="devnet"
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"
NEXT_PUBLIC_SOLANA_RPC_WS_URL="wss://api.devnet.solana.com"

# Umbra browser SDK indexer endpoint. Replace with the endpoint for your selected network.
NEXT_PUBLIC_UMBRA_INDEXER_API_ENDPOINT="https://replace-with-umbra-indexer.example"

# Umbra browser SDK relayer endpoint for receiver claim transactions.
NEXT_PUBLIC_UMBRA_RELAYER_API_ENDPOINT="https://replace-with-umbra-relayer.example"

# Cloak devnet relay used by @cloak.dev/sdk-devnet.
NEXT_PUBLIC_CLOAK_RELAY_URL="https://api.devnet.cloak.ag"

# Gemini structured intent parsing. If unset, ShadeOps uses deterministic fallback parsing.
GOOGLE_GENERATIVE_AI_API_KEY=""

# Treasury context provider. Prefer ZERION_API_KEY in hosted environments.
ZERION_API_KEY=""

# Optional local Zerion CLI fallback for development only.
ZERION_CLI_PATH="zerion"
ZERION_CLI_ARGS=""
